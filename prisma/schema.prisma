generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  INTERNAL
  EXTERNAL
}

enum FoodType {
  MAINCOURSE
  DESSERT
  APPETIZER
}

model User {
  id    String   @id @default(uuid())
  name  String
  email String @unique
  jabatan AccountType
  isActive  Boolean  @default(true)
  password  String   @unique @db.VarChar(255)


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]

}

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  hashedToken String
  isRevoked   Boolean  @default(false)

  createdBy   String
  updatedBy   String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Food {
  id          Int      @id @default(autoincrement())
  title       String
  subtitle    String
  price       Int
  description String?
  stock       Int
  type        FoodType
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}